{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lms": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio local",
      "options": { "baseURL": "http://127.0.0.1:1234/v1" },
      "models": {
        "qwen/qwen3-coder-next": { "name": "Qwen3 Coder Next (local)" },
        "qwen/qwen3.6-35b-a3b": { "name": "Qwen3.6 35B A3B (local)" }
      }
    }
  },
  "agent": {
    "em": {
      "mode": "primary",
      "model": "[EM_MODEL]",
      "prompt": "{file:./.opencode/prompts/em.md}",
      "permission": {
        "edit": {
          "src/**": "deny",
          "tests/**": "deny",
          "docs/**": "deny",
          "scripts/**": "deny",
          "tasks/**": "allow"
        }
      }
    },
    "coder": {
      "mode": "primary",
      "model": "lms/qwen/qwen3.6-35b-a3b",
      "prompt": "{file:./.opencode/prompts/coder.md}",
      "permission": {
        "edit": {
          "tests/**": "deny",
          "tasks/**": "deny",
          "docs/**": "deny",
          "scripts/**": "deny",
          "**": "allow"
        }
      }
    }
  }
}
